{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "website",
  "main": ".open-next/worker.js",
  "compatibility_date": "2026-07-15",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "r2_buckets": [
    { "binding": "R2_BUCKET", "bucket_name": "websiteassets" }
  ],
  "vars": {
    "NEXT_PUBLIC_SANITY_DATASET": "production",
    "NEXT_PUBLIC_SANITY_PROJECT_ID": "r6mln4n3",
    "NEXT_PUBLIC_USE_CLOUDFLARE_R2": "true",
    "R2_BUCKET_NAME": "websiteassets",
    "R2_ENDPOINT": "https://930b5248e181432aa6e2f5a31832fd8d.r2.cloudflarestorage.com"
  }
}
