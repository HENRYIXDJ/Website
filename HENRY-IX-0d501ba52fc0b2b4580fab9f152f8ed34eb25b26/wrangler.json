{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "website",
  "main": ".open-next/worker.js",
  "compatibility_date": "2026-07-15",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "r2_buckets": [
    { "binding": "R2_BUCKET", "bucket_name": "websiteassets" }
  ],
  "observability": {
    "logs": {
      "enabled": true,
      "invocation_logs": true
    }
  },
  "vars": {
    "NEXT_PUBLIC_SANITY_DATASET": "production",
    "NEXT_PUBLIC_SANITY_PROJECT_ID": "r6mln4n3",
    "NEXT_PUBLIC_USE_CLOUDFLARE_R2": "true",
    "R2_BUCKET_NAME": "websiteassets",
    "R2_ENDPOINT": "https://c7c5ff43a8ae174ad91e2668de0ad7f0.r2.cloudflarestorage.com",
    "NEXT_PUBLIC_STORAGE_BASE_URL": "https://pub-c7c5ff43a8ae174ad91e2668de0ad7f0.r2.dev",
    "GOOGLE_CALENDAR_ID": "5b5f645880a3408ee94d4cd64091ed3f84a52cdeb901923f11c0cdfbb793555a@group.calendar.google.com"
  }
}
